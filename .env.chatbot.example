# Advanced Chatbot Features - Environment Variables

# ==============================================
# TWILIO CONFIGURATION (SMS & WhatsApp Notifications)
# ==============================================
# Sign up at: https://www.twilio.com/
# Get credentials from: https://console.twilio.com/

TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=+1234567890

# ==============================================
# BKASH PAYMENT GATEWAY
# ==============================================
# Sign up at: https://www.bkash.com/
# Sandbox: https://developer.bka sh.com/

BKASH_APP_KEY=your_bkash_app_key
BKASH_APP_SECRET=your_bkash_app_secret
BKASH_USERNAME=your_bkash_username
BKASH_PASSWORD=your_bkash_password
BKASH_BASE_URL=https://checkout.sandbox.bkash.com

# ==============================================
# NAGAD PAYMENT GATEWAY
# ==============================================
# Sign up at: https://nagad.com.bd/

NAGAD_MERCHANT_ID=your_merchant_id
NAGAD_MERCHANT_NUMBER=your_merchant_number
NAGAD_PUBLIC_KEY=your_public_key
NAGAD_PRIVATE_KEY=your_private_key
NAGAD_BASE_URL=http://sandbox.mynagad.com:10080/remote-payment-gateway-1.0

# ==============================================
# SSL COMMERZ PAYMENT GATEWAY
# ==============================================
# Sign up at: https://www.sslcommerz.com/
# Sandbox: https://sandbox.sslcommerz.com/

SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASSWORD=your_store_password
SSLCOMMERZ_IS_SANDBOX=True

# ==============================================
# SITE CONFIGURATION
# ==============================================
SITE_URL=http://localhost:8000
SUPPORT_PHONE=+880 1609132361

# ==============================================
# OPTIONAL: GOOGLE CLOUD (for advanced features)
# ==============================================
# For Speech-to-Text and Vision API (future features)
# GOOGLE_CLOUD_PROJECT_ID=your_project_id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json
